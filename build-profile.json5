{
  "app": {
    "signingConfigs": [

    ],
    "products": [
      {
        "name": "default",
        "signingConfig": "default",
        "compatibleSdkVersion": "6.1.0(23)",
        "targetSdkVersion": "6.1.0(23)",
        "runtimeOS": "HarmonyOS",
        "buildOption": {
          "nativeCompiler": "BiSheng"
        }
      }
    ],
    "buildModeSet": [
      {
        "name": "debug",
        "buildOption": {
          "debuggable": true,
          "externalNativeOptions": {
            "path": "./entry/src/main/cpp/CMakeLists.txt",
            "arguments": "",
            "abiFilters": [
              "arm64-v8a",
              "x86_64"
            ],
            "cppFlags": ""
          }
        }
      },
      {
        "name": "release",
        "buildOption": {
          "debuggable": false
        }
      }
    ]
  },
  "modules": [
    {
      "name": "entry",
      "srcPath": "./entry",
      "targets": [
        {
          "name": "default",
          "applyToProducts": [
            "default"
          ]
        }
      ]
    }
  ]
}
